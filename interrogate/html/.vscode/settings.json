{
  "eslint.enable": true,
  "prettier.enable": true,
  "editor.formatOnSave": true,
  "prettier.configPath": "./prettier.config.mjs",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never",
    "source.sortImports": "never"
  },
  "eslint.validate": [
    "vue",
    "xml",
    "yaml",
    "toml",
    "json",
    "jsonc",
    "json5",
    "markdown",
    "javascript",
    "typescript",
    "javascriptreact",
    "typescriptreact"
  ],
  "cSpell.useGitignore": true,
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "antfu",
    "antv",
    "bumpp",
    "Cascader",
    "changelogithub",
    "dagre",
    "darkbg",
    "defu",
    "Destructurable",
    "dxup",
    "echarts",
    "esbuild",
    "iconify",
    "Kaldi",
    "lucide",
    "nocheck",
    "nums",
    "oxfmt",
    "oxlint",
    "pinia",
    "pptxs",
    "recordrtc",
    "Segoe",
    "tsbuildinfo",
    "unimport",
    "unplugin",
    "unrs",
    "videojs",
    "VITE",
    "vosk",
    "vueuse",
    "wrinkler",
    "xgplayer",
    "xinchuang"
  ]
}
